---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = `${site.name} — Professional Garage Door Services`,
  description = site.description,
  canonical = site.url,
  schema,
} = Astro.props;

const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonical}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=DM+Serif+Display&display=swap" rel="stylesheet">
  {schemas.map((item) => (
    <script type="application/ld+json" set:html={JSON.stringify(item)} />
  ))}
</head>
<body>
  <slot />
  <script src="/js/main.js" defer></script>
</body>
</html>
