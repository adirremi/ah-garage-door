---
import { site, businessHours } from '../data/site';
---

<!-- TOP BAR -->
<div class="topbar">
  <div class="container">
    <div class="topbar-left">
      <span><span class="topbar-dot"></span> {businessHours.topbar}</span>
      <span>Serving All of California</span>
    </div>
    <a href={site.phoneHref}>{site.phone}</a>
  </div>
</div>

<!-- HEADER -->
<header class="site-header">
  <div class="container">
    <a href="/" class="logo">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#0B1D3A" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="13" x2="21" y2="13"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </div>
      <div class="logo-text">
        <div class="name">{site.name}</div>
        <div class="tagline">{site.tagline}</div>
      </div>
    </a>
    <nav class="main-nav">
      <a href="#services">Services</a>
      <a href="#why-us">Why Us</a>
      <a href="#locations">Locations</a>
      <a href="#reviews">Reviews</a>
      <a href="#faq">FAQ</a>
      <a href={site.phoneHref} class="nav-cta">Call Now</a>
    </nav>
    <button class="mobile-toggle" id="mobile-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
