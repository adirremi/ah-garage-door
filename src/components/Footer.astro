---
import { site, businessHours } from '../data/site';

const year = new Date().getFullYear();
---

<!-- CTA BANNER -->
<section class="cta-banner">
  <div class="container">
    <p class="section-label" style="color:var(--gold-light)">Ready to get started?</p>
    <h2>Fix or Upgrade Your Garage Door Today</h2>
    <p>Contact us now for a free estimate. Fast, professional service across California.</p>
    <div class="cta-buttons">
      <a href={site.phoneHref} class="btn btn-gold">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        Call {site.phone}
      </a>
      <a href="#locations" class="btn btn-outline">Find a Location</a>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo">
          <div class="logo-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#0B1D3A" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="13" x2="21" y2="13"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </div>
          <div class="logo-text">
            <div class="name">{site.name}</div>
            <div class="tagline">{site.tagline}</div>
          </div>
        </a>
        <p>Your trusted garage door experts across California. Professional repair, installation, and maintenance services backed by years of experience and a satisfaction guarantee.</p>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <a href="#services">Our Services</a>
        <a href="#why-us">Why Choose Us</a>
        <a href="#locations">Service Areas</a>
        <a href="#reviews">Reviews</a>
      </div>
      <div class="footer-col">
        <h4>Services</h4>
        <a href="#">Installation</a>
        <a href="#">Repair</a>
        <a href="#">Maintenance</a>
        <a href="#">Emergency Repairs</a>
        <a href="#">Commercial</a>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <a href={site.phoneHref}>{site.phone}</a>
        <a href={`mailto:${site.email}`}>{site.email}</a>
        <span style="display:block;font-size:14px;padding:4px 0;line-height:1.6;">{businessHours.short}</span>
      </div>
    </div>
    <div class="footer-bottom">
      &copy; {year} AH Garage Door LLC | All Rights Reserved
    </div>
  </div>
</footer>
